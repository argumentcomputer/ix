module
public import Ix.Aiur.Meta

/-!
# Keccak-256 in Aiur (value-based, wide permutation circuit)

Same algorithm/variant as `Ix/MultiStark/Keccak.lean` (Ethereum keccak-256:
pad `10*1`, rate 136, capacity 512) but shaped for the FFT cost model
(width x height x log2(height)): lanes and the 25-lane state are plain
values (no pointers, no memory traffic), the 24 rounds unroll into ONE
permutation circuit via `fold` (one row per keccak-f call), and rotations
are static bit recompositions (decompose once, recompose at compile-time
offsets) instead of runtime bit lists. theta's rotl-by-1 skips
decomposition entirely: `u8_add(b, b)` yields `(2b mod 256, msb)` and the
even low byte absorbs the neighbor's carry with a free field add.

Generated by a script (rho+pi is 24 distinct static bit wirings); the
pi/rho wiring is asserted against the MultiStark listing at generation
time.
-/

public section

namespace IxVM

-- The unrolled 24-round permutation elaborates to one deeply nested let
-- chain; the default recursion budget is not enough.
set_option maxRecDepth 65536 in
def keccak := ⟦
  /- # Test entrypoints -/

  pub fn keccak256_test() -> [[U8; 8]; 4] {
    let (idx, len) = io_get_info(0, [0]);
    let byte_stream = #read_byte_stream(0, idx, len);
    keccak256(byte_stream)
  }

  /- # Benchmark entrypoints -/

  pub fn keccak256_bench(num_hashes: G) -> G {
    let num_hashes_pred = num_hashes - 1;
    let key = [num_hashes_pred];
    let (idx, len) = io_get_info(0, key);
    let byte_stream = #read_byte_stream(0, idx, len);
    keccak256(byte_stream);
    match num_hashes_pred {
      0 => 0,
      _ => keccak256_bench(num_hashes_pred),
    }
  }

  /- # Sponge -/

  -- Pull one rate byte from the stream, injecting pad10*1 when the
  -- message is exhausted. `first_pad` is 1 until the first pad byte is
  -- emitted (which carries the 0x01 bit); position 135 carries 0x80
  -- (0x81 when both coincide). No store on the real-byte path — the
  -- block is consumed directly, not copied into a 136-node list.
  fn take_byte(stream: ByteStream, pos: G, first_pad: G) -> (U8, ByteStream, G) {
    match load(stream) {
      ListNode.Cons(b, rest) => (b, rest, first_pad),
      ListNode.Nil =>
        (u8_from_field_unsafe(first_pad + 128 * eq_zero(135 - pos)),
         store(ListNode.Nil), 0),
    }
  }

  -- Pull 8 consecutive rate bytes (one lane) from the stream, threading
  -- position and the pad flag. Factored out of absorb_blocks so the
  -- 136-byte walk is one reused circuit, not 136 inline lets in the
  -- toplevel AST (which overflows the elaborator).
  fn take_lane(stream: ByteStream, pos: G, first_pad: G) -> ([U8; 8], ByteStream, G) {
    let (b0, st, fp) = take_byte(stream, pos, first_pad);
    let (b1, st, fp) = take_byte(st, pos + 1, fp);
    let (b2, st, fp) = take_byte(st, pos + 2, fp);
    let (b3, st, fp) = take_byte(st, pos + 3, fp);
    let (b4, st, fp) = take_byte(st, pos + 4, fp);
    let (b5, st, fp) = take_byte(st, pos + 5, fp);
    let (b6, st, fp) = take_byte(st, pos + 6, fp);
    let (b7, st, fp) = take_byte(st, pos + 7, fp);
    ([b0, b1, b2, b3, b4, b5, b6, b7], st, fp)
  }

  -- Absorb one 136-byte rate block (17 lanes) directly from the stream
  -- into the state, permute, and recurse while whole real blocks keep
  -- filling (first_pad still 1 after 136 bytes). `first_pad` resets to 1
  -- per block: only a fully-real block recurses, so a fresh block never
  -- starts mid-pad.
  fn absorb_blocks(stream: ByteStream, s: [[U8; 8]; 25]) -> [[U8; 8]; 25] {
    let (rl0, st, fp) = take_lane(stream, 0, 1);
    let (rl1, st, fp) = take_lane(st, 8, fp);
    let (rl2, st, fp) = take_lane(st, 16, fp);
    let (rl3, st, fp) = take_lane(st, 24, fp);
    let (rl4, st, fp) = take_lane(st, 32, fp);
    let (rl5, st, fp) = take_lane(st, 40, fp);
    let (rl6, st, fp) = take_lane(st, 48, fp);
    let (rl7, st, fp) = take_lane(st, 56, fp);
    let (rl8, st, fp) = take_lane(st, 64, fp);
    let (rl9, st, fp) = take_lane(st, 72, fp);
    let (rl10, st, fp) = take_lane(st, 80, fp);
    let (rl11, st, fp) = take_lane(st, 88, fp);
    let (rl12, st, fp) = take_lane(st, 96, fp);
    let (rl13, st, fp) = take_lane(st, 104, fp);
    let (rl14, st, fp) = take_lane(st, 112, fp);
    let (rl15, st, fp) = take_lane(st, 120, fp);
    let (rl16, st, fp) = take_lane(st, 128, fp);
    let s = set(s, 0, [u8_xor(s[0][0], rl0[0]), u8_xor(s[0][1], rl0[1]), u8_xor(s[0][2], rl0[2]), u8_xor(s[0][3], rl0[3]), u8_xor(s[0][4], rl0[4]), u8_xor(s[0][5], rl0[5]), u8_xor(s[0][6], rl0[6]), u8_xor(s[0][7], rl0[7])]);
    let s = set(s, 1, [u8_xor(s[1][0], rl1[0]), u8_xor(s[1][1], rl1[1]), u8_xor(s[1][2], rl1[2]), u8_xor(s[1][3], rl1[3]), u8_xor(s[1][4], rl1[4]), u8_xor(s[1][5], rl1[5]), u8_xor(s[1][6], rl1[6]), u8_xor(s[1][7], rl1[7])]);
    let s = set(s, 2, [u8_xor(s[2][0], rl2[0]), u8_xor(s[2][1], rl2[1]), u8_xor(s[2][2], rl2[2]), u8_xor(s[2][3], rl2[3]), u8_xor(s[2][4], rl2[4]), u8_xor(s[2][5], rl2[5]), u8_xor(s[2][6], rl2[6]), u8_xor(s[2][7], rl2[7])]);
    let s = set(s, 3, [u8_xor(s[3][0], rl3[0]), u8_xor(s[3][1], rl3[1]), u8_xor(s[3][2], rl3[2]), u8_xor(s[3][3], rl3[3]), u8_xor(s[3][4], rl3[4]), u8_xor(s[3][5], rl3[5]), u8_xor(s[3][6], rl3[6]), u8_xor(s[3][7], rl3[7])]);
    let s = set(s, 4, [u8_xor(s[4][0], rl4[0]), u8_xor(s[4][1], rl4[1]), u8_xor(s[4][2], rl4[2]), u8_xor(s[4][3], rl4[3]), u8_xor(s[4][4], rl4[4]), u8_xor(s[4][5], rl4[5]), u8_xor(s[4][6], rl4[6]), u8_xor(s[4][7], rl4[7])]);
    let s = set(s, 5, [u8_xor(s[5][0], rl5[0]), u8_xor(s[5][1], rl5[1]), u8_xor(s[5][2], rl5[2]), u8_xor(s[5][3], rl5[3]), u8_xor(s[5][4], rl5[4]), u8_xor(s[5][5], rl5[5]), u8_xor(s[5][6], rl5[6]), u8_xor(s[5][7], rl5[7])]);
    let s = set(s, 6, [u8_xor(s[6][0], rl6[0]), u8_xor(s[6][1], rl6[1]), u8_xor(s[6][2], rl6[2]), u8_xor(s[6][3], rl6[3]), u8_xor(s[6][4], rl6[4]), u8_xor(s[6][5], rl6[5]), u8_xor(s[6][6], rl6[6]), u8_xor(s[6][7], rl6[7])]);
    let s = set(s, 7, [u8_xor(s[7][0], rl7[0]), u8_xor(s[7][1], rl7[1]), u8_xor(s[7][2], rl7[2]), u8_xor(s[7][3], rl7[3]), u8_xor(s[7][4], rl7[4]), u8_xor(s[7][5], rl7[5]), u8_xor(s[7][6], rl7[6]), u8_xor(s[7][7], rl7[7])]);
    let s = set(s, 8, [u8_xor(s[8][0], rl8[0]), u8_xor(s[8][1], rl8[1]), u8_xor(s[8][2], rl8[2]), u8_xor(s[8][3], rl8[3]), u8_xor(s[8][4], rl8[4]), u8_xor(s[8][5], rl8[5]), u8_xor(s[8][6], rl8[6]), u8_xor(s[8][7], rl8[7])]);
    let s = set(s, 9, [u8_xor(s[9][0], rl9[0]), u8_xor(s[9][1], rl9[1]), u8_xor(s[9][2], rl9[2]), u8_xor(s[9][3], rl9[3]), u8_xor(s[9][4], rl9[4]), u8_xor(s[9][5], rl9[5]), u8_xor(s[9][6], rl9[6]), u8_xor(s[9][7], rl9[7])]);
    let s = set(s, 10, [u8_xor(s[10][0], rl10[0]), u8_xor(s[10][1], rl10[1]), u8_xor(s[10][2], rl10[2]), u8_xor(s[10][3], rl10[3]), u8_xor(s[10][4], rl10[4]), u8_xor(s[10][5], rl10[5]), u8_xor(s[10][6], rl10[6]), u8_xor(s[10][7], rl10[7])]);
    let s = set(s, 11, [u8_xor(s[11][0], rl11[0]), u8_xor(s[11][1], rl11[1]), u8_xor(s[11][2], rl11[2]), u8_xor(s[11][3], rl11[3]), u8_xor(s[11][4], rl11[4]), u8_xor(s[11][5], rl11[5]), u8_xor(s[11][6], rl11[6]), u8_xor(s[11][7], rl11[7])]);
    let s = set(s, 12, [u8_xor(s[12][0], rl12[0]), u8_xor(s[12][1], rl12[1]), u8_xor(s[12][2], rl12[2]), u8_xor(s[12][3], rl12[3]), u8_xor(s[12][4], rl12[4]), u8_xor(s[12][5], rl12[5]), u8_xor(s[12][6], rl12[6]), u8_xor(s[12][7], rl12[7])]);
    let s = set(s, 13, [u8_xor(s[13][0], rl13[0]), u8_xor(s[13][1], rl13[1]), u8_xor(s[13][2], rl13[2]), u8_xor(s[13][3], rl13[3]), u8_xor(s[13][4], rl13[4]), u8_xor(s[13][5], rl13[5]), u8_xor(s[13][6], rl13[6]), u8_xor(s[13][7], rl13[7])]);
    let s = set(s, 14, [u8_xor(s[14][0], rl14[0]), u8_xor(s[14][1], rl14[1]), u8_xor(s[14][2], rl14[2]), u8_xor(s[14][3], rl14[3]), u8_xor(s[14][4], rl14[4]), u8_xor(s[14][5], rl14[5]), u8_xor(s[14][6], rl14[6]), u8_xor(s[14][7], rl14[7])]);
    let s = set(s, 15, [u8_xor(s[15][0], rl15[0]), u8_xor(s[15][1], rl15[1]), u8_xor(s[15][2], rl15[2]), u8_xor(s[15][3], rl15[3]), u8_xor(s[15][4], rl15[4]), u8_xor(s[15][5], rl15[5]), u8_xor(s[15][6], rl15[6]), u8_xor(s[15][7], rl15[7])]);
    let s = set(s, 16, [u8_xor(s[16][0], rl16[0]), u8_xor(s[16][1], rl16[1]), u8_xor(s[16][2], rl16[2]), u8_xor(s[16][3], rl16[3]), u8_xor(s[16][4], rl16[4]), u8_xor(s[16][5], rl16[5]), u8_xor(s[16][6], rl16[6]), u8_xor(s[16][7], rl16[7])]);
    let s2 = keccak_f(s);
    match fp {
      1 => absorb_blocks(st, s2),
      _ => s2,
    }
  }

  -- keccak-256: absorb into the zero state, squeeze lanes 0..3.
  fn keccak256(bytes: ByteStream) -> [[U8; 8]; 4] {
    let s = absorb_blocks(bytes, [[0u8; 8]; 25]);
    [s[0], s[1], s[2], s[3]]
  }

  /- # keccak-f[1600]: 24 unrolled rounds of theta-rho-pi-chi-iota -/

  fn keccak_f(s: [[U8; 8]; 25]) -> [[U8; 8]; 25] {
    let RC = [
      [0x01u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x82u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x8au8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0u8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x8bu8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x01u8, 0u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0u8],
      [0x81u8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x09u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x8au8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x88u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x09u8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0u8],
      [0x0au8, 0u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0u8],
      [0x8bu8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0u8],
      [0x8bu8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x89u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x03u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x02u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x0au8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8],
      [0x0au8, 0u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x81u8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x80u8, 0x80u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0x80u8],
      [0x01u8, 0u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0u8],
      [0x08u8, 0x80u8, 0u8, 0x80u8, 0u8, 0u8, 0u8, 0x80u8]
    ];
    fold(0 .. 24, s, |s, @i| keccak_rho_chi_iota(keccak_theta(s), RC[@i]))
  }

  -- One round, split into two circuits (theta | rho+pi+chi+iota), each of
  -- height 24 x permutations. A single fully-unrolled permutation circuit
  -- would be cheaper (no 200-column state re-input or 200 output aux per
  -- call, one row per permutation at a 24x shorter height's log2), but its
  -- ~7300-let macro-expanded body overflows the Lean elaborator's stack.
  -- Building the Source.Term programmatically would unlock it.
  fn keccak_theta(s: [[U8; 8]; 25]) -> [[U8; 8]; 25] {
      -- theta: column parities C[x] = xor of the 5 lanes in column x.
      let c0 = [
        u8_xor(s[20][0], u8_xor(s[15][0], u8_xor(s[10][0], u8_xor(s[5][0], s[0][0])))),
        u8_xor(s[20][1], u8_xor(s[15][1], u8_xor(s[10][1], u8_xor(s[5][1], s[0][1])))),
        u8_xor(s[20][2], u8_xor(s[15][2], u8_xor(s[10][2], u8_xor(s[5][2], s[0][2])))),
        u8_xor(s[20][3], u8_xor(s[15][3], u8_xor(s[10][3], u8_xor(s[5][3], s[0][3])))),
        u8_xor(s[20][4], u8_xor(s[15][4], u8_xor(s[10][4], u8_xor(s[5][4], s[0][4])))),
        u8_xor(s[20][5], u8_xor(s[15][5], u8_xor(s[10][5], u8_xor(s[5][5], s[0][5])))),
        u8_xor(s[20][6], u8_xor(s[15][6], u8_xor(s[10][6], u8_xor(s[5][6], s[0][6])))),
        u8_xor(s[20][7], u8_xor(s[15][7], u8_xor(s[10][7], u8_xor(s[5][7], s[0][7]))))
      ];
      let c1 = [
        u8_xor(s[21][0], u8_xor(s[16][0], u8_xor(s[11][0], u8_xor(s[6][0], s[1][0])))),
        u8_xor(s[21][1], u8_xor(s[16][1], u8_xor(s[11][1], u8_xor(s[6][1], s[1][1])))),
        u8_xor(s[21][2], u8_xor(s[16][2], u8_xor(s[11][2], u8_xor(s[6][2], s[1][2])))),
        u8_xor(s[21][3], u8_xor(s[16][3], u8_xor(s[11][3], u8_xor(s[6][3], s[1][3])))),
        u8_xor(s[21][4], u8_xor(s[16][4], u8_xor(s[11][4], u8_xor(s[6][4], s[1][4])))),
        u8_xor(s[21][5], u8_xor(s[16][5], u8_xor(s[11][5], u8_xor(s[6][5], s[1][5])))),
        u8_xor(s[21][6], u8_xor(s[16][6], u8_xor(s[11][6], u8_xor(s[6][6], s[1][6])))),
        u8_xor(s[21][7], u8_xor(s[16][7], u8_xor(s[11][7], u8_xor(s[6][7], s[1][7]))))
      ];
      let c2 = [
        u8_xor(s[22][0], u8_xor(s[17][0], u8_xor(s[12][0], u8_xor(s[7][0], s[2][0])))),
        u8_xor(s[22][1], u8_xor(s[17][1], u8_xor(s[12][1], u8_xor(s[7][1], s[2][1])))),
        u8_xor(s[22][2], u8_xor(s[17][2], u8_xor(s[12][2], u8_xor(s[7][2], s[2][2])))),
        u8_xor(s[22][3], u8_xor(s[17][3], u8_xor(s[12][3], u8_xor(s[7][3], s[2][3])))),
        u8_xor(s[22][4], u8_xor(s[17][4], u8_xor(s[12][4], u8_xor(s[7][4], s[2][4])))),
        u8_xor(s[22][5], u8_xor(s[17][5], u8_xor(s[12][5], u8_xor(s[7][5], s[2][5])))),
        u8_xor(s[22][6], u8_xor(s[17][6], u8_xor(s[12][6], u8_xor(s[7][6], s[2][6])))),
        u8_xor(s[22][7], u8_xor(s[17][7], u8_xor(s[12][7], u8_xor(s[7][7], s[2][7]))))
      ];
      let c3 = [
        u8_xor(s[23][0], u8_xor(s[18][0], u8_xor(s[13][0], u8_xor(s[8][0], s[3][0])))),
        u8_xor(s[23][1], u8_xor(s[18][1], u8_xor(s[13][1], u8_xor(s[8][1], s[3][1])))),
        u8_xor(s[23][2], u8_xor(s[18][2], u8_xor(s[13][2], u8_xor(s[8][2], s[3][2])))),
        u8_xor(s[23][3], u8_xor(s[18][3], u8_xor(s[13][3], u8_xor(s[8][3], s[3][3])))),
        u8_xor(s[23][4], u8_xor(s[18][4], u8_xor(s[13][4], u8_xor(s[8][4], s[3][4])))),
        u8_xor(s[23][5], u8_xor(s[18][5], u8_xor(s[13][5], u8_xor(s[8][5], s[3][5])))),
        u8_xor(s[23][6], u8_xor(s[18][6], u8_xor(s[13][6], u8_xor(s[8][6], s[3][6])))),
        u8_xor(s[23][7], u8_xor(s[18][7], u8_xor(s[13][7], u8_xor(s[8][7], s[3][7]))))
      ];
      let c4 = [
        u8_xor(s[24][0], u8_xor(s[19][0], u8_xor(s[14][0], u8_xor(s[9][0], s[4][0])))),
        u8_xor(s[24][1], u8_xor(s[19][1], u8_xor(s[14][1], u8_xor(s[9][1], s[4][1])))),
        u8_xor(s[24][2], u8_xor(s[19][2], u8_xor(s[14][2], u8_xor(s[9][2], s[4][2])))),
        u8_xor(s[24][3], u8_xor(s[19][3], u8_xor(s[14][3], u8_xor(s[9][3], s[4][3])))),
        u8_xor(s[24][4], u8_xor(s[19][4], u8_xor(s[14][4], u8_xor(s[9][4], s[4][4])))),
        u8_xor(s[24][5], u8_xor(s[19][5], u8_xor(s[14][5], u8_xor(s[9][5], s[4][5])))),
        u8_xor(s[24][6], u8_xor(s[19][6], u8_xor(s[14][6], u8_xor(s[9][6], s[4][6])))),
        u8_xor(s[24][7], u8_xor(s[19][7], u8_xor(s[14][7], u8_xor(s[9][7], s[4][7]))))
      ];
      -- rotl-by-1 of each C lane via the u8_add trick: (b + b) yields
      -- (2b mod 256, msb); the even low byte absorbs the neighbor byte's
      -- msb with a free field add.
      let (l0_0, m0_0) = u8_add(c0[0], c0[0]);
      let (l0_1, m0_1) = u8_add(c0[1], c0[1]);
      let (l0_2, m0_2) = u8_add(c0[2], c0[2]);
      let (l0_3, m0_3) = u8_add(c0[3], c0[3]);
      let (l0_4, m0_4) = u8_add(c0[4], c0[4]);
