{
  "_comment": "Single registry for the benchmark pipeline. Consumed by `ix bench` (Ix/Cli/BenchCmd.lean), the !benchmark comment parser (.github/scripts/bench.py), and matrix generation in the bench workflows. Vectors.csv (same directory) holds the per-constant rows; this file holds everything else that used to be hand-copied across bench.py, run.sh, and the workflow YAML.",
  "envs": {
    "initStd": { "slug": "InitStd", "module": "Benchmarks/Compile/CompileInitStd.lean", "benched": true },
    "lean":    { "slug": "Lean",    "module": "Benchmarks/Compile/CompileLean.lean",    "benched": false },
    "mathlib": { "slug": "Mathlib", "module": "Benchmarks/Compile/CompileMathlib.lean", "benched": true },
    "flt":     { "slug": "FLT",     "module": "Benchmarks/Compile/CompileFLT.lean",     "benched": false }
  },
  "backends": {
    "aiur": {
      "enabled": true,
      "default_mode": "prove",
      "testbed": {
        "prove": "aiur-prove-x64-32x",
        "execute": "aiur-execute-x64-32x"
      },
      "metrics": {
        "prove":   ["fft-cost", "execute-time", "prove-time", "verify-time", "proof-size", "peak-rss"],
        "execute": ["fft-cost", "execute-time", "throughput", "peak-rss"]
      }
    },
    "zisk": {
      "enabled": true,
      "default_mode": "execute",
      "testbed": "zisk-check-x64-32x",
      "metrics": {
        "execute": ["cycles", "execute-time", "throughput", "peak-rss"]
      }
    },
    "sp1": {
      "enabled": false,
      "disabled_reason": "execute run too slow for per-push CI; re-enable here once trimmed",
      "default_mode": "execute",
      "testbed": "sp1-check-x64-32x",
      "metrics": {
        "execute": ["cycles", "execute-time", "throughput", "peak-rss"]
      }
    },
    "ooc": {
      "enabled": true,
      "default_mode": "execute",
      "testbed": "ooc-check-x64-32x",
      "metrics": {
        "execute": ["throughput", "check-time", "peak-rss"]
      }
    },
    "compile": {
      "enabled": true,
      "default_mode": "execute",
      "testbed": "ix-compile-x64-32x",
      "metrics": {
        "execute": ["compile-time", "throughput", "file-size", "constants", "peak-rss"]
      }
    }
  },
  "runner": "warp-ubuntu-latest-x64-32x",
  "ram_ceiling_gb": 120,
  "higher_is_better": ["throughput"]
}
